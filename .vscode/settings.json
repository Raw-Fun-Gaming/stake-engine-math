{
    "yaml.schemas": {
        "https://squidfunk.github.io/mkdocs-material/schema.json": "mkdocs.yml"
      },
      "yaml.customTags": [
        "!ENV scalar",
        "!ENV sequence",
        "!relative scalar",
        "tag:yaml.org,2002:python/name:material.extensions.emoji.to_svg",
        "tag:yaml.org,2002:python/name:material.extensions.emoji.twemoji",
        "tag:yaml.org,2002:python/name:pymdownx.superfences.fence_code_format",
        "tag:yaml.org,2002:python/object/apply:pymdownx.slugs.slugify mapping"
      ],
    "cSpell.words": [
        "reelset",
        "buybonus",
        "tumble",
        "payout",
        "paytable",
        "payline",
        "paylines",
        "winCap",
        "scatterpay",
        "neighbours",
        "JSONL",
        "zstd",
        "toml",
        "tomli",
        "tomllib",
        "xlsxwriter",
        "pyproject",
        "pytest",
        "numpy",
        "mypy",
        "mkdocs"
    ],

    // Performance optimizations for Python project
    "python.terminal.activateEnvironment": false,
    "terminal.integrated.inheritEnv": false,
    "terminal.integrated.processIdleTimeout": 60000,
    "terminal.integrated.shellIntegration.historySize": 0,
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.ptyHost.maxIdleTime": 30000,

    // Disable web development extensions for this Python project
    "svelte.enable": false,
    "eslint.enable": false,
    "prettier.enable": false,
    "tailwindCSS.enable": false,

    // Optimize Python-specific settings
    "python.analysis.autoImportCompletions": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.completeFunctionParens": true,

    // Reduce extension overhead
    "extensions.experimental.affinity": {
        "ms-python.python": 1,
        "ms-python.vscode-pylance": 1,
        "ms-python.debugpy": 1
    },

    // Disable unnecessary features
    "git.decorations.enabled": false,
    "workbench.tips.enabled": false,
    "workbench.startupEditor": "none",

    // File watching optimization
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/env/**": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/*.pyc": true,
        "**/target/**": true
    },

    // Hide build artifacts from explorer
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/env": true,
        "**/.pytest_cache": true
    },

    // Exclude build artifacts from search
    "search.exclude": {
        "**/build/**": true,
        "**/target/**": true,
        "**/env/**": true,
        "**/*.jsonl": true
    }
}
